{
  "name": "@preship/cli",
  "version": "0.1.0",
  "description": "CLI tool for PreShip - scan your site for accessibility, security, and performance issues",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "preship": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
