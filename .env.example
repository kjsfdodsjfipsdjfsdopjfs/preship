# ──────────────────────────────────────────────────────────────────────
# LOCAL DEV MODE (no Docker, PostgreSQL, or Redis required)
# ──────────────────────────────────────────────────────────────────────
#
# To run locally without any external services:
#
#   cd apps/api
#   npx tsx src/local.ts
#
# Or from the project root:
#
#   npm run dev:local -w @preship/api
#
# This uses:
#   - SQLite instead of PostgreSQL (stored in apps/api/data/preship.db)
#   - In-memory queue instead of BullMQ/Redis
#   - Mocked billing (free plan only)
#   - A pre-seeded API key: pk_local_dev
#
# No .env file is required for local dev mode. The settings below are
# only needed for the full production setup with Docker.
# ──────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://localhost:5432/preship

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (for LLM fix suggestions)
OPENAI_API_KEY=sk-...

# App
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NODE_ENV=development

# API Key hashing
API_KEY_SALT=your-api-key-salt-here

# Scanning
SCAN_TIMEOUT=60000
MAX_PAGES=50

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
